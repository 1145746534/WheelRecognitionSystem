<mah:MetroWindow x:Class="WheelRecognitionSystem.Views.MainView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controlzEx="urn:controlzex"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WheelRecognitionSystem.Views"
        xmlns:p="http://prismlibrary.com/"
        xmlns:c="clr-namespace:WheelRecognitionSystem.Public.Converter"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen" FontFamily="Microsoft YaHei" FontSize="13" Foreground="#333" FontWeight="ExtraLight"
        Title="长沙戴卡-终检系统" Icon="{StaticResource icon}" 
        Height="1000" Width="1580" MinHeight="600" MinWidth="800"
       
                 >

    <Window.Resources>
        <c:BackgroundConverter x:Key="BackgroundConverter"/>
        <BooleanToVisibilityConverter x:Key="btv"/>
    </Window.Resources>
    <Border BorderThickness ="{Binding WindowThickness, RelativeSource={RelativeSource AncestorType=Window}}" Background="#F7F9FA">
        <Grid x:Name="mainView">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition/>
                <RowDefinition Height="200"/>
            </Grid.RowDefinitions>
            <Menu Grid.Row="0" Margin="1" HorizontalAlignment="Left" VerticalAlignment="Stretch">

                <MenuItem Header="系统设置" FontSize="12" Foreground="#444">
                    <MenuItem Header="参数管理" Foreground="#444" Command="{Binding ClickCommand}"  CommandParameter="文件管理" FontSize="11" />
                    <MenuItem Header="数据库设置" Foreground="#444" FontSize="11"/>
                </MenuItem>
                <MenuItem Header="报表管理" Foreground="#444" Command="{Binding ClickCommand}" CommandParameter="报表管理"   FontSize="12"/>
                <!--<MenuItem Header="大模型更新" Command="{Binding ClickCommand}"  CommandParameter="大模型更新" FontSize="12" />-->
                <MenuItem Header="图片查看" Foreground="#444" Command="{Binding ClickCommand}"  CommandParameter="图片查看" FontSize="12" />
                <MenuItem Header="模板制作" Foreground="#444" Command="{Binding ClickCommand}"  CommandParameter="模板制作" FontSize="12" />

            </Menu>
            <mah:MetroAnimatedSingleRowTabControl  x:Name="MainTabControl"  Grid.Row="1">
                <TabItem Header="显示界面" Tag="DisplayInterfaceView">
                    <ContentControl p:RegionManager.RegionName="ViewRegion" />
                </TabItem>
                <!--<TabItem Header="报表管理" Tag="SystemSettingsView">
                    <ContentControl p:RegionManager.RegionName="ViewRegion1" />
                </TabItem>-->
            </mah:MetroAnimatedSingleRowTabControl>

            <Border Grid.Row="2" Background="#F7F9FA">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>


                    <Border Grid.Column="0" Background="White" CornerRadius="15" Padding="5">
                        <DataGrid x:Name="AzureDataGrid" Grid.Column="0" Margin="5"  CanUserAddRows="False" IsReadOnly="True"
                            AutoGenerateColumns="False" ItemsSource="{Binding Path=DisplayCollections}" RowHeaderWidth="0"
                            Style="{DynamicResource MahApps.Styles.DataGrid.Azure}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Width="1.5*" Binding="{Binding Station}" Header="工站" />
                                <DataGridTextColumn Width="1.5*" Binding="{Binding Status}" Header="状态" />
                                <DataGridTextColumn Width="1.5*" Binding="{Binding WheelType}" Header="轮型" />
                                <DataGridTemplateColumn Width="1.5*" Header="相似度">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <mah:MetroProgressBar x:Name="PriceProgressBar"
                                          Height="20"
                                          Margin="5 2"
                                          VerticalAlignment="Center"
                                          Background="Transparent"
                                          Foreground="{DynamicResource MahApps.Brushes.Accent}"
                                          Maximum="100"
                                          Minimum="0"
                                          Value="{Binding Similarity}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Width="0.8*" Binding="{Binding TimeConsumed}" Header="用时" />
                                <DataGridTextColumn Width="3*" Binding="{Binding Remark}" Header="说明" />

                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <Grid Grid.Column="1" Margin="10,5,4,5" >
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <Border Margin="1,11,94,145" CornerRadius="7" Background="White" BorderThickness="1" >
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="97*"/>
                                    <ColumnDefinition Width="49*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="2*"/>
                                    <RowDefinition Height="1.2*" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="PLC连接" Grid.Row="0" VerticalAlignment="Center" FontSize="14" FontWeight="Bold" Grid.ColumnSpan="2" Margin="3,0,0,0"/>
                                <TextBlock Text="{Binding PLCIP}" Foreground="Green" FontSize="8" Grid.Row="1" VerticalAlignment="Center" Grid.ColumnSpan="2" Margin="3,0,0,0"/>
                                <Border Grid.Row="1" Grid.Column="1" Background="{Binding PlcStatus, Converter={StaticResource BackgroundConverter}}" CornerRadius="5" >
                                    <TextBlock Text="状态" FontSize="9" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </Grid>
                        </Border>

                        <Button Content="测试"  FontSize="14" Style="{StaticResource UltraFlatButtonStyle}"  Margin="0,50,94,105" Visibility="Visible" Command="{Binding BtuCommand}" CommandParameter="测试" Cursor="Hand"/>
                        <Button Content="参数刷新" Background="White" FontSize="14"  Margin="97,10,0,145" Command="{Binding BtuCommand}" CommandParameter="参数刷新" 
                                HorizontalAlignment="Left" BorderThickness="0" Width="85" Cursor ="Hand"/>
                        <Button Content="模板刷新" Background="White" FontSize="14"  Margin="97,50,0,105" Command="{Binding BtuCommand}" CommandParameter="模板刷新" 
                                HorizontalAlignment="Left" BorderThickness="0" Width="85" Cursor ="Hand"/>
                        <mah:Badged Width="85"  Margin="94,92,0,62"  Badge="{Binding NGCount}"  IsEnabled="True">
                            <Button Content="NG图识别" BorderThickness="0"  Background="White"  FontSize="14" Command="{Binding BtuCommand}" CommandParameter="NG图识别"
                                    Cursor ="Hand"/>
                        </mah:Badged>
                    </Grid>
                    <GroupBox Grid.Column="3" Style="{StaticResource NewGroupBoxStyle}" Header="信息显示" Margin="5">
                        <TextBox VirtualizingStackPanel.VirtualizationMode="Recycling" VirtualizingStackPanel.IsVirtualizing="True" Style="{StaticResource NewTextBoxStyle}" Name="SystemMessage" Margin="5,28,5,5" IsReadOnly="True" FontSize="14" VerticalContentAlignment="Top"
                             VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" HorizontalContentAlignment="Left"/>
                    </GroupBox>
                   
                </Grid>
            </Border>

        </Grid>
    </Border>
</mah:MetroWindow>
