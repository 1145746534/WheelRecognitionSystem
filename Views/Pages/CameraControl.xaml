<UserControl x:Class="WheelRecognitionSystem.Views.Pages.CameraControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:h="clr-namespace:HalconDotNet;assembly=halcondotnet"
             xmlns:local="clr-namespace:WheelRecognitionSystem.Views.Pages"
             mc:Ignorable="d" 
             d:DesignHeight="400" d:DesignWidth="500" Background="AntiqueWhite" >
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="9*"/>
            </Grid.RowDefinitions>
            <Border Background="White" CornerRadius="10" Margin="0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,0">
                    <Border CornerRadius="10">
                    <ProgressBar Width="30" Background="Green" 
                                 Margin="4,7,1,7"
                                 IsIndeterminate="{Binding IsIndeterminate}"
                                 Maximum="100" Minimum="0"/>
                    </Border>
                    <Label Content="{Binding DisplayName}" FontSize="14" Foreground="#FF424141"  VerticalAlignment="Center"></Label>
                    <mah:ToggleSwitch OnContent="关闭实时" OffContent="开启实时" FontFamily="Microsoft YaHei UI" 
                                      OffCommand="{Binding SwitchOffCommand}"
                                      OnCommand="{Binding SwitchOnCommand}"  />
                    <Button Style="{StaticResource UltraFlatButtonStyle}" Command="{Binding BtnTakePhotoCommand}" Width="50" Content="拍照"  
                            Background="#999" Margin="0,4,0,4" Cursor ="Hand"/>
                    <Button Style="{StaticResource UltraFlatButtonStyle}" Command="{Binding BtnLinkCommand}" Width="50" Content="连接" 
                            Background="#999" Margin="1,4,0,4" Cursor ="Hand"/>
                    <Button Style="{StaticResource UltraFlatButtonStyle}" Command="{Binding BtnSaveCommand}" Width="50" Content="保存"  
                            Background="#999" Margin="1,4,0,4" Cursor ="Hand"/>
                    <Label Content="{Binding FullGray}" Margin="1,4,0,4"></Label>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="4" >
                <h:HSmartWindowControlWPF x:Name="hWindowControlWPF1"   HKeepAspectRatio="True" HLineWidth="2">
                    <h:HIconicDisplayObjectWPF IconicObject="{Binding CurrentImage}"/>
                    <h:HIconicDisplayObjectWPF IconicObject="{Binding WheelContour}" HColor="magenta"/>
                    <h:HIconicDisplayObjectWPF IconicObject="{Binding TemplateContour}" HColor="medium slate blue"/>
                </h:HSmartWindowControlWPF>
            </Border>
        </Grid>
    </Grid>
</UserControl>
